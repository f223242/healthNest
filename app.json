{
  "expo": {
    "name": "HealthNest",
    "slug": "HealthNest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/png/HealthNest.png",
    "scheme": "healthnest",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/png/HealthNest.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#00C389",
        "foregroundImage": "./assets/png/HealthNest.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.healthnest.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/png/HealthNest.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/png/HealthNest.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#00C389"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
