rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      // Allow read if:
      // 1. Authenticated and accessing own document, OR
      // 2. Unauthenticated but querying by phone number (for password reset)
      allow read: if request.auth != null && request.auth.uid == userId
                  || request.auth == null;  // Allow unauthenticated queries for password reset
      
      // Allow create during registration (user creates their own document)
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow update if authenticated and updating own document
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Don't allow delete
      allow delete: if false;
    }
    
    // Pending Users collection (for unverified users)
    match /pendingUsers/{userId} {
      // Allow create during registration
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow read for checking verification status
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow delete when moving to users collection
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // No updates needed
      allow update: if false;
    }
    
    // Password Reset OTPs collection
    // NOTE: For development we allow creation so the client can write OTP docs.
    // Reads/updates/deletes are restricted to the authenticated owner (the user UID stored on the document).
    // In production you should prefer a server-side callable function instead of allowing unauthenticated
    // writes or reads to this collection.
    match /passwordResetOTPs/{docId} {
      // Allow creation so the client can save generated OTPs for dev verification.
      allow create: if true;

      // Only allow read/update/delete for authenticated users whose UID matches the OTP doc's uid.
      allow read, update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Public phone index: maps normalized phone -> { uid, email }
    // Purpose: allow unauthenticated lookups by exact phone doc ID (no list queries),
    // so clients can verify a phone belongs to an account without exposing the whole users collection.
    match /publicPhoneIndex/{phoneId} {
      // Allow getting a specific phone-id document from the client (unauthenticated),
      // but disallow listing all phone index docs.
      allow get: if true;
      allow list: if false;

      // Creation allowed only by authenticated user and must set uid equal to their auth.uid.
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;

      // Allow update/delete only by the owning user.
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}
