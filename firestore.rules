rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      // Allow get (single document) if:
      // - Authenticated owner, OR
      // - Admin user (custom claim `admin`), OR
      // - Unauthenticated (keep existing dev behavior for phone-based lookups)
      allow get: if (request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true))
                   || request.auth == null;

      // Allow list for authenticated users (development convenience).
      // NOTE: In production you should restrict this to admin users only.
      allow list: if request.auth != null;

      // Allow create during registration (user creates their own document)
      allow create: if request.auth != null && request.auth.uid == userId;

      // Allow update if authenticated and updating own document
      allow update: if request.auth != null && request.auth.uid == userId;

      // Don't allow delete
      allow delete: if false;
    }
    
    // Pending Users collection (for unverified users)
    match /pendingUsers/{userId} {
      // Allow create during registration (owner only)
      allow create: if request.auth != null && request.auth.uid == userId;

      // Allow get by owner or by admin users (set via custom claim `admin`)
      allow get: if request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true);

      // Allow list for authenticated users (development convenience).
      // NOTE: In production you should restrict this to admin users only.
      allow list: if request.auth != null;

      // Allow delete by owner or admin (used when moving to `users` collection)
      allow delete: if request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true);

      // No updates needed
      allow update: if false;
    }
    
    // Password Reset OTPs collection
    // NOTE: For development we allow creation so the client can write OTP docs.
    // Reads/updates/deletes are restricted to the authenticated owner (the user UID stored on the document).
    // In production you should prefer a server-side callable function instead of allowing unauthenticated
    // writes or reads to this collection.
    match /passwordResetOTPs/{docId} {
      // Allow creation so the client can save generated OTPs for dev verification.
      allow create: if true;

      // Only allow read/update/delete for authenticated users whose UID matches the OTP doc's uid.
      allow read, update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Public phone index: maps normalized phone -> { uid, email }
    // Purpose: allow unauthenticated lookups by exact phone doc ID (no list queries),
    // so clients can verify a phone belongs to an account without exposing the whole users collection.
    match /publicPhoneIndex/{phoneId} {
      // Allow getting a specific phone-id document from the client (unauthenticated),
      // but disallow listing all phone index docs.
      allow get: if true;
      allow list: if false;

      // Creation allowed only by authenticated user and must set uid equal to their auth.uid.
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;

      // Allow update/delete only by the owning user.
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Conversations collection for chat
    match /conversations/{conversationId} {
      // Allow read/write if authenticated (development)
      allow read, write: if request.auth != null;
    }

    // Messages collection for chat messages
    match /messages/{messageId} {
      // Allow read/write if authenticated (development)
      allow read, write: if request.auth != null;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // Allow read/write if authenticated (development)
      allow read, write: if request.auth != null;
    }

    // Appointments collection
    match /appointments/{appointmentId} {
      // Allow read if user is the patient or the nurse in the appointment
      allow read: if request.auth != null;
      
      // Allow create for authenticated users (patients booking appointments)
      allow create: if request.auth != null;
      
      // Allow update for authenticated users who are involved in the appointment
      allow update: if request.auth != null;
      
      // Don't allow delete (appointments should be cancelled instead)
      allow delete: if false;
    }
  }
}
