rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      // Allow read if authenticated and accessing own document
      // Also allow querying by phone number for password reset (unauthenticated)
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow create during registration (user creates their own document)
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow update if authenticated and updating own document
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Don't allow delete
      allow delete: if false;
    }
    
    // Pending Users collection (for unverified users)
    match /pendingUsers/{userId} {
      // Allow create during registration
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow read for checking verification status
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow delete when moving to users collection
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // No updates needed
      allow update: if false;
    }
    
    // Password Reset OTPs collection (separate collection for security)
    match /passwordResetOTPs/{docId} {
      // Anyone can create (for password reset flow when user is not authenticated)
      allow create: if true;
      
      // Anyone can read (to verify OTP)
      allow read: if true;
      
      // Anyone can update (to mark OTP as used)
      allow update: if true;
      
      // Allow delete after verification
      allow delete: if true;
    }
  }
}
